# =============================================================================
# CLAW-Agent Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values below.
# This file controls credentials, API endpoints, and operational modes.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. JLab Logbook API Credentials
#    Required for fetching shift summaries and logbook entries.
# -----------------------------------------------------------------------------
JLAB_USERNAME=
JLAB_PASSWORD=

# -----------------------------------------------------------------------------
# 2. LLM Operation Mode (Choose ONE mode below)
# -----------------------------------------------------------------------------
# The project supports TWO modes for LLM inference:
#
# MODE A: OpenClaw CLI (Recommended if you have OpenClaw installed)
#   - Set OPENCLAW_PATH to your OpenClaw installation directory
#   - The project will use `openclaw agent` subprocess calls
#   - AGENT_NAME must be configured in OpenClaw
#
# MODE B: Direct vLLM API (Use if OPENCLAW_PATH is empty)
#   - Leave OPENCLAW_PATH empty (below)
#   - The project will call vLLM REST API directly
#   - Configure VLLM_BASE_URL and VLLM_MODEL_NAME below
#
# -----------------------------------------------------------------------------
# LLM Agent Name (used only in OpenClaw CLI mode)
AGENT_NAME=

# OpenClaw Installation Path
#   - Set to your OpenClaw installation directory (e.g., ~/.npm-global/lib/node_modules/openclaw)
#   - Leave EMPTY to use vLLM API directly instead
#   - Example: OPENCLAW_PATH=/home/user/.npm-global/lib/node_modules/openclaw
OPENCLAW_PATH=

# vLLM Configuration (used only when OPENCLAW_PATH is empty)
#   - vLLM API endpoint URL. Example: http://localhost:8000
VLLM_BASE_URL=
#   - Model name registered with your vLLM instance
VLLM_MODEL_NAME=
#   - API key if your vLLM instance requires authentication (leave empty if not needed)
VLLM_API_KEY=

# -----------------------------------------------------------------------------
# 3. Logging Configuration
# -----------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 4. SSH Tunnel Configuration (Optional)
# -----------------------------------------------------------------------------
# Required if your network needs SSH tunneling to reach the JLab Logbook API or other __.
# If SSH_USERNAME or SSH_HOST are empty, all tunnel operations are skipped.
#
# Format for tunnels: SSH_TUNNEL_N_LOCAL=<local_port> and SSH_TUNNEL_N_REMOTE=<remote_port>
# Add as many tunnels as needed (1, 2, 3, etc.) or remove all to disable tunneling.
#
SSH_USERNAME=
SSH_HOST=

# Tunnel 1: JLab Logbook API (example)
SSH_TUNNEL_1_LOCAL=8000
SSH_TUNNEL_1_REMOTE=8000


# -----------------------------------------------------------------------------
# 5. Dashboard Server Configuration (Optional)
# -----------------------------------------------------------------------------
# Separate SSH credentials for deploying the Streamlit dashboard to a remote server.
#
# If DASHBOARD_SSH_USERNAME or DASHBOARD_SSH_HOST are empty:
#   - The dashboard runs LOCALLY on your machine
#   - No SSH deployment or tunneling occurs
#
# If both are set:
#   - The dashboard is deployed to the remote server via SSH
#   - Access it via SSH tunnel: ssh -L <local_port>:localhost:<remote_port> <user>@<host>
#
DASHBOARD_SSH_USERNAME=
DASHBOARD_SSH_HOST=
DASHBOARD_SSH_PORT=
DASHBOARD_REMOTE_PORT=

# =============================================================================
# Quick Reference: How to Configure
# =============================================================================
#
# To use OpenClaw CLI:
#   OPENCLAW_PATH=/home/user/.npm-global/lib/node_modules/openclaw
#   (Leave VLLM_* variables as-is, they will be ignored)
#
# To use vLLM directly:
#   OPENCLAW_PATH=
#   VLLM_BASE_URL=http://localhost:8000
#   VLLM_MODEL_NAME=qwen3-32b
#
# To disable SSH tunneling:
#   Comment out or remove SSH_USERNAME and SSH_HOST lines
#
# To run dashboard locally:
#   Comment out DASHBOARD_SSH_USERNAME and DASHBOARD_SSH_HOST lines
#
# =============================================================================